   "source": [
    "# ABOUT TRAJECTORY FILE FROM THE HYSPLIT MODEL"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "a20ba622",
   "metadata": {
    "papermill": {
     "duration": 0.002588,
     "end_time": "2026-07-19T12:18:59.263774+00:00",
     "exception": false,
     "start_time": "2026-07-19T12:18:59.261186+00:00",
     "status": "completed"
    },
    "tags": []
   },
   "source": [
    "## Reading Your Actual File\n",
    "Looking at your data, Record #6 (the data rows) looks like this:\n",
    "\n",
    "     1     1    20     9    21     0     0     0     0.0   34.052 -118.244    500.0    943.3    301.4    296.4      0.0\n",
    "  [traj] [grid] [yr] [mo] [dy] [hr] [min] [fhr] [age]   [lat]    [lon]     [alt]  [pres]  [theta] [airtemp] [rain]\n",
    "\n",
    "  \n",
    "Your file has 2 trajectories (trajectory 1 = 500m start, trajectory 2 = 300m start) and 4 diagnostic variables: PRESSURE, THETA, AIR_TEMP, RAINFALL."
   ]
  },
  {
   "cell_type": "markdown",
   "id": "88291993",
   "metadata": {
    "papermill": {
     "duration": 0.002755,
     "end_time": "2026-07-19T12:18:59.269250+00:00",
     "exception": false,
     "start_time": "2026-07-19T12:18:59.266495+00:00",
     "status": "completed"
    },
    "tags": []
   },
   "source": [
    "## parser"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "0cc6a375",
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-07-19T12:18:59.276332Z",
     "iopub.status.busy": "2026-07-19T12:18:59.275965Z",
     "iopub.status.idle": "2026-07-19T12:18:59.284099Z",
     "shell.execute_reply": "2026-07-19T12:18:59.283453Z"
    },
    "papermill": {
     "duration": 0.013308,
     "end_time": "2026-07-19T12:18:59.285498+00:00",
     "exception": false,
     "start_time": "2026-07-19T12:18:59.272190+00:00",
     "status": "completed"
    },
    "tags": []
   },
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import geopandas as gpd\n",
    "from shapely.geometry import Point\n",
    "\n",
    "def parse_tdump(filepath):\n",
    "    rows = []\n",
    "    \n",
    "    with open(filepath, 'r') as f:\n",
    "        lines = f.readlines()\n",
    "    \n",
    "    for line in lines:\n",
    "        parts = line.strip().split()\n",
    "        \n",
    "        # data lines have 15 columns (6 base + fhr + age + lat + lon + alt + 4 diag vars)\n",
    "        if len(parts) < 15:\n",
    "            continue\n",
    "        \n",
    "        try:\n",
    "            traj_num  = int(parts[0])\n",
    "            grid_num  = int(parts[1])\n",
    "            year      = int(parts[2])\n",
    "            month     = int(parts[3])\n",
    "            day       = int(parts[4])\n",
    "            hour      = int(parts[5])\n",
    "            minute    = int(parts[6])\n",
    "            fhour     = int(parts[7])\n",
    "            age       = float(parts[8])   # negative = backward hours\n",
    "            lat       = float(parts[9])\n",
    "            lon       = float(parts[10])\n",
    "            alt       = float(parts[11])\n",
    "            pressure  = float(parts[12])\n",
    "            theta     = float(parts[13])\n",
    "            air_temp  = float(parts[14])\n",
    "            rainfall  = float(parts[15]) if len(parts) > 15 else None\n",
    "            \n",
    "            rows.append({\n",
    "                'traj_num': traj_num,\n",
    "                'year': year, 'month': month, 'day': day,\n",
    "                'hour': hour, 'minute': minute,\n",
    "                'age_hours': age,\n",
    "                'lat': lat, 'lon': lon, 'alt': alt,\n",
    "                'pressure': pressure,\n",
    "                'theta': theta,\n",
    "                'air_temp': air_temp,\n",
    "                'rainfall': rainfall\n",
    "            })\n",
    "        except (ValueError, IndexError):\n",
    "            continue  # skip header lines cleanly\n",
    "    \n",
    "    df = pd.DataFrame(rows)\n",
    "    \n",
    "    # create proper datetime column\n",
    "    df['datetime'] = pd.to_datetime({\n",
    "        'year':  2000 + df['year'],   # HYSPLIT uses 2-digit year\n",
    "        'month': df['month'],\n",
    "        'day':   df['day'],\n",
    "        'hour':  df['hour']\n",
    "    })\n",
    "    \n",
    "    return df\n",
    "\n"
   ]
  },
