sIO(r.content))\n","z.extractall('/kaggle/working/counties/')\n","\n","counties = gpd.read_file('/kaggle/working/counties/cb_2020_us_county_20m.shp')\n","counties = counties.to_crs('EPSG:4326')\n","\n","# spatial join — find which county each trajectory point falls in\n","joined = gpd.sjoin(\n","    gdf1,  # your GeoDataFrame from parsed traj1\n","    counties[['GEOID', 'NAME', 'STATEFP', 'geometry']],\n","    how='left',\n","    predicate='within'\n",")\n","\n","print(joined[['datetime', 'age_hours', 'lat', 'lon', 'alt', 'GEOID', 'NAME', 'STATEFP']].head(20))"]},{"cell_type":"code","execution_count":13,"id":"a24d599d","metadata":{"execution":{"iopub.execute_input":"2026-07-20T13:04:57.542337Z","iopub.status.busy":"2026-07-20T13:04:57.541567Z","iopub.status.idle":"2026-07-20T13:04:58.939858Z","shell.execute_reply":"2026-07-20T13:04:58.93883Z"},"papermill":{"duration":1.409786,"end_time":"2026-07-20T13:04:58.941706+00:00","exception":false,"start_time":"2026-07-20T13:04:57.53192+00:00","status":"completed"},"tags":[]},"outputs":[{"name":"stdout","output_type":"stream","text":["(3221, 13)\n","['STATEFP', 'COUNTYFP', 'COUNTYNS', 'AFFGEOID', 'GEOID', 'NAME', 'NAMELSAD', 'STUSPS', 'STATE_NAME', 'LSAD', 'ALAND', 'AWATER', 'geometry']\n"]}],"source":["import requests, zipfile, io\n","\n","# download US counties shapefile\n","url = \"https://www2.census.gov/geo/tiger/GENZ2020/shp/cb_2020_us_county_20m.zip\"\n","r = requests.get(url)\n","z = zipfile.ZipFile(io.BytesIO(r.content))\n","z.extractall('/kaggle/working/counties/')\n","\n","counties = gpd.read_file('/kaggle/working/counties/cb_2020_us_county_20m.shp')\n","counties = counties.to_crs('EPSG:4326')\n","print(counties.shape)\n","print(counties.columns.tolist())"]},{"cell_type":"code","execution_count":14,"id":"6d8aef3d","metadata":{"execution":{"iopub.execute_input":"2026-07-20T13:04:58.960987Z","iopub.status.busy":"2026-07-20T13:04:58.960212Z","iopub.status.idle":"2026-07-20T13:04:58.975729Z","shell.execute_reply":"2026-07-20T13:04:58.974885Z"},"papermill":{"duration":0.026348,"end_time":"2026-07-20T13:04:58.977213+00:00","exception":false,"start_time":"2026-07-20T13:04:58.950865+00:00","status":"completed"},"tags":[]},"outputs":[{"name":"stdout","output_type":"stream","text":["              datetime  age_hours     lat      lon  GEOID         NAME\n","0  2020-09-21 00:00:00        0.0  34.052 -118.244  06037  Los Angeles\n","1  2020-09-20 23:00:00       -1.0  33.992 -118.240  06037  Los Angeles\n","2  2020-09-20 22:00:00       -2.0  33.930 -118.235  06037  Los Angeles\n","3  2020-09-20 21:00:00       -3.0  33.868 -118.238  06037  Los Angeles\n","4  2020-09-20 20:00:00       -4.0  33.814 -118.233  06037  Los Angeles\n","5  2020-09-20 19:00:00       -5.0  33.776 -118.202  06037  Los Angeles\n","6  2020-09-20 18:00:00       -6.0  33.747 -118.142    NaN          NaN\n","7  2020-09-20 17:00:00       -7.0  33.720 -118.066  06059       Orange\n","8  2020-09-20 16:00:00       -8.0  33.690 -117.993  06059       Orange\n","9  2020-09-20 15:00:00       -9.0  33.659 -117.925  06059       Orange\n","10 2020-09-20 14:00:00      -10.0  33.624 -117.862  06059       Orange\n","11 2020-09-20 13:00:00      -11.0  33.580 -117.803  06059       Orange\n","12 2020-09-20 12:00:00      -12.0  33.529 -117.749  06059       Orange\n","13 2020-09-20 11:00:00      -13.0  33.474 -117.709  06059       Orange\n","14 2020-09-20 10:00:00      -14.0  33.422 -117.690    NaN          NaN\n","15 2020-09-20 09:00:00      -15.0  33.375 -117.690    NaN          NaN\n","16 2020-09-20 08:00:00      -16.0  33.338 -117.705    NaN          NaN\n","17 2020-09-20 07:00:00      -17.0  33.317 -117.734    NaN          NaN\n","18 2020-09-20 06:00:00      -18.0  33.313 -117.777    NaN          NaN\n","19 2020-09-20 05:00:00      -19.0  33.321 -117.838    NaN          NaN\n","Ocean/outside US points: 64\n","Land/county points:      15\n"]}],"source":["joined = gpd.sjoin(\n","    gdf1,\n","    counties[['GEOID', 'NAME', 'STATEFP', 'geometry']],\n","    how='left',\n","    predicate='within'\n",")\n","\n","print(joined[['datetime', 'age_hours', 'lat', 'lon', 'GEOID', 'NAME']].head(20))\n","print(f\"Ocean/outside US points: {joined['GEOID'].isna().sum()}\")\n","print(f\"Land/county points:      {joined['GEOID'].notna().sum()}\")"]},{"cell_type":"markdown","id":"f4eae882","metadata":{"papermill":{"duration":0.008668,"end_time":"2026-07-20T13:04:58.994432+00:00","exception":false,"start_time":"2026-07-20T13:04:58.985764+00:00","status":"completed"},"tags":[]},"source":["# Step 4 Compute Transport Weight Per County\n","For each day's trajectory, you need one number per county — how much influence did that county have on LA's air that day."]},{"cell_type":"code","execution_count":15,"id":"28478d97","metadata":{"execution":{"iopub.execute_input":"2026-07-20T13:04:59.013259Z","iopub.status.busy":"2026-07-20T13:04:59.012578Z","iopub.status.idle":"2026-07-20T13:04:59.025073Z","shell.execute_reply":"2026-07-20T13:04:59.024388Z"},"papermill":{"duration":0.023354,"end_time":"2026-07-20T13:04:59.026563+00:00","exception":false,"start_time":"2026-07-20T13:04:59.003209+00:00","status":"completed"},"tags":[]},"outputs":[],"source":["import numpy as np\n","\n","def compute_weights(joined_df):\n","    # keep only points matched to a US county\n","    land_points = joined_df.dropna(subset=['GEOID']).copy()\n","    \n","    # convert age_hours to positive lag\n","    land_points['lag'] = land_points['age_hours'].abs()\n","    \n","    # exponential decay weight\n","    land_points['weight'] = np.exp(-land_points['lag'] / 24)\n","    \n","    # sum weights per county\n","    county_weights = (\n","        land_points.groupby(['GEOID', 'NAME'])['weight']\n","        .sum()\n","        .reset_index()\n","        .rename(columns={'weight': 'transport_weight'})\n","    )\n","    \n","    # normalise so all weights sum to 1\n","    county_weights['transport_weight'] /= county_weights['transport_weight'].sum()\n","    \n","    return county_weights, land_points\n","\n","county_weights, land_points = compute_weights(joined)\n","\n","# print(\"=== Transport Weights by County ===\")\n","# print(county_weights.sort_values('transport_weight', ascending=False))\n","# print(f\"\\nTotal weight (should be 1.0): {county_weights['transport_weight'].sum():.4f}\")"]},{"cell_type":"code","execution_count":16,"id":"551fcf59","metadata":{"execution":{"iopub.execute_input":"2026-07-20T13:04:59.046452Z","iopub.status.busy":"2026-07-20T13:04:59.04624Z","iopub.status.idle":"2026-07-20T13:04:59.051771Z","shell.execute_reply":"2026-07-20T13:04:59.051092Z"},"papermill":{"duration":0.018262,"end_time":"2026-07-20T13:04:59.053379+00:00","exception":false,"start_time":"2026-07-20T13:04:59.035117+00:00","status":"completed"},"tags":[]},"outputs":[{"name":"stdout","output_type":"stream","text":["   GEOID           NAME  transport_weight\n","0  06037    Los Angeles          0.543407\n","1  06059         Orange          0.434754\n","2  06083  Santa Barbara          0.021840\n"]}],"source":["print(county_weights.sort_values('transport_weight', ascending=False).head(10))"]},{"cell_type":"code","execution_count":17,"id":"45e687bc","metadata":{"execution":{"iopub.execute_input":"2026-07-20T13:04:59.072745Z","iopub.status.busy":"2026-07-20T13:04:59.072494Z","iopub.status.idle":"2026-07-20T13:04:59.084362Z","shell.execute_reply":"2026-07-20T13:04:59.083542Z"},"papermill":{"duration":0.023333,"end_time":"2026-07-20T13:04:59.085933+00:00","exception":false,"start_time":"2026-07-20T13:04:59.0626+00:00","status":"completed"},"tags":[]},"outputs":[{"name":"stdout","output_type":"stream","text":["=== Transport Weights by County ===\n","   GEOID           NAME  transport_weight\n","0  06037    Los Angeles          0.543407\n","1  06059         Orange          0.434754\n","2  06083  Santa Barbara          0.021840\n","\n","Total weight (should be 1.0): 1.0000\n"]}],"source":["county_weights, land_points = compute_weights(joined)\n","\n","print(\"=== Transport Weights by County ===\")\n","print(county_weights.sort_values('transport_weight', ascending=False))\n","print(f\"\\nTotal weight (should be 1.0): {county_weights['transport_weight'].sum():.4f}\")"]},{"cell_type":"markdown","id":"b3a42a7d","metadata":{"papermill":{"duration":0.008451,"end_time":"2026-07-20T13:04:59.103317+00:00","exception":false,"start_time":"2026-07-20T13:04:59.094866+00:00","status":"completed"},"tags":[]},"source":["# Step 5 — Link to PM2.5 Data"]},{"cell_type":"code","execution_count":18,"id":"c5b72dfb","metadata":{"execution":{"iopub.execute_input":"2026-07-20T13:04:59.121642Z","iopub.status.busy":"2026-07-20T13:04:59.121371Z","iopub.status.idle":"2026-07-20T13:05:00.050713Z","shell.execute_reply":"2026-07-20T13:05:00.049821Z"},"papermill":{"duration":0.94017,"end_time":"2026-07-20T13:05:00.052249+00:00","exception":false,"start_time":"2026-07-20T13:04:59.112079+00:00","status":"completed"},"tags":[]},"outputs":[{"name":"stdout","output_type":"stream","text":["Transport-weighted PM2.5 arriving in LA on Sep 21 2020: 18.690 µg/m³\n"]}],"source":["# fix date column in PM2.5 data first\n","pm['date'] = pd.to_datetime(pm['date'])\n","pm['GEOID'] = pm['county_fips'].astype(str).str.zfill(5)  # match county shapefile format\n","\n","# for a single trajectory starting Sep 21 2020:\n","# the trajectory covers Sep 18–21, so we need PM2.5 for those dates per county\n","\n","# get the date each trajectory point corresponds to\n","joined['point_date'] = joined['datetime'].dt.date\n","\n","# merge weights with PM2.5\n","def link_pm25(county_weights, joined, pm):\n","    # get date range covered by this trajectory\n","    result_rows = []\n","    \n","    land_points = joined.dropna(subset=['GEOID']).copy()\n","    land_points['lag'] = land_points['age_hours'].abs()\n","    import numpy as np\n","    land_points['weight'] = np.exp(-land_points['lag'] / 24)\n","    land_points['point_date'] = pd.to_datetime(land_points['datetime']).dt.date\n","    land_points['GEOID'] = land_points['GEOID'].astype(str).str.zfill(5)\n","    \n","    # for each point, get that county's PM2.5 on that date\n","    land_points['point_date_dt'] = pd.to_datetime(land_points['point_date'])\n","    \n","    merged = land_points.merge(\n","        pm[['GEOID', 'date', 'pm25_ushigh']],\n","        left_on=['GEOID', 'point_date_dt'],\n","        right_on=['GEOID', 'date'],\n","        how='left'\n","    )\n","    \n","    # transport-weighted PM2.5 = sum(weight × pm25) / sum(weight)\n","    merged['weighted_pm25'] = merged['weight'] * merged['pm25_ushigh']\n","    \n","    transport_weighted_pm25 = (\n","        merged['weighted_pm25'].sum() / merged['weight'].sum()\n","    )\n","    \n","    return transport_weighted_pm25\n","\n","tw_pm25 = link_pm25(county_weights, joined, pm)\n","print(f\"Transport-weighted PM2.5 arriving in LA on Sep 21 2020: {tw_pm25:.3f} µg/m³\")"]},{"cell_type":"code","execution_count":19,"id":"dc26faf5","metadata":{"execution":{"iopub.execute_input":"2026-07-20T13:05:00.072394Z","iopub.status.busy":"2026-07-20T13:05:00.071814Z","iopub.status.idle":"2026-07-20T13:05:00.904742Z","shell.execute_reply":"2026-07-20T13:05:00.90361Z"},"papermill":{"duration":0.844915,"end_time":"2026-07-20T13:05:00.906422+00:00","exception":false,"start_time":"2026-07-20T13:05:00.061507+00:00","status":"completed"},"tags":[]},"outputs":[{"name":"stdout","output_type":"stream","text":["=== Merged Trajectory + PM2.5 ===\n","              datetime  age_hours  GEOID           NAME    weight  pm25_ushigh\n","0  2020-09-21 00:00:00        0.0  06037    Los Angeles  1.000000    25.925027\n","1  2020-09-20 23:00:00       -1.0  06037    Los Angeles  0.959189    21.752326\n","2  2020-09-20 22:00:00       -2.0  06037    Los Angeles  0.920044    21.752326\n","3  2020-09-20 21:00:00       -3.0  06037    Los Angeles  0.882497    21.752326\n","4  2020-09-20 20:00:00       -4.0  06037    Los Angeles  0.846482    21.752326\n","5  2020-09-20 19:00:00       -5.0  06037    Los Angeles  0.811936    21.752326\n","6  2020-09-20 17:00:00       -7.0  06059         Orange  0.747018    14.364710\n","7  2020-09-20 16:00:00       -8.0  06059         Orange  0.716531    14.364710\n","8  2020-09-20 15:00:00       -9.0  06059         Orange  0.687289    14.364710\n","9  2020-09-20 14:00:00      -10.0  06059         Orange  0.659241    14.364710\n","10 2020-09-20 13:00:00      -11.0  06059         Orange  0.632337    14.364710\n","11 2020-09-20 12:00:00      -12.0  06059         Orange  0.606531    14.364710\n","12 2020-09-20 11:00:00      -13.0  06059         Orange  0.581778    14.364710\n","13 2020-09-20 00:00:00      -24.0  06037    Los Angeles  0.367879    21.752326\n","14 2020-09-19 13:00:00      -35.0  06083  Santa Barbara  0.232624    10.674347\n","\n","=== Transport-Weighted PM2.5 arriving in LA on Sep 21 2020 ===\n","18.690 µg/m³\n"]}],"source":["# other method \n","# fix date column types\n","pm['date'] = pd.to_datetime(pm['date'])\n","pm['GEOID'] = pm['county_fips'].astype(str).str.zfill(5)\n","\n","# prepare land points for merge\n","land_points['GEOID'] = land_points['GEOID'].astype(str).str.zfill(5)\n","land_points['point_date'] = pd.to_datetime(land_points['datetime']).dt.normalize()\n","\n","# merge each trajectory point with PM2.5 for that county on that date\n","merged = land_points.merge(\n","    pm[['GEOID', 'date', 'pm25_ushigh']],\n","    left_on=['GEOID', 'point_date'],\n","    right_on=['GEOID', 'date'],\n","    how='left'\n",")\n","\n","print(\"=== Merged Trajectory + PM2.5 ===\")\n","print(merged[['datetime', 'age_hours', 'GEOID', 'NAME', 'weight', 'pm25_ushigh']].to_string())\n","\n","# compute transport-weighted PM2.5\n","merged['weighted_pm25'] = merged['weight'] * merged['pm25_ushigh']\n","\n","valid = merged.dropna(subset=['pm25_ushigh'])\n","if len(valid) > 0:\n","    transport_weighted_pm25 = valid['weighted_pm25'].sum() / valid['weight'].sum()\n","else:\n","    transport_weighted_pm25 = np.nan\n","\n","print(f\"\\n=== Transport-Weighted PM2.5 arriving in LA on Sep 21 2020 ===\")\n","print(f\"{transport_weighted_pm25:.3f} µg/m³\")"]},{"cell_type":"markdown","id":"d1e1f4eb","metadata":{"papermill":{"duration":0.008774,"end_time":"2026-07-20T13:05:00.924591+00:00","exception":false,"start_time":"2026-07-20T13:05:00.915817+00:00","status":"completed"},"tags":[]},"source":["# STEP 6 — Feasibility Check \n","LA's county FIPS is 06037 — that last line tells you what LA's actual PM2.5 was on that day, which is what regression will eventually try to predict."]},{"cell_type":"code","execution_count":20,"id":"54d9d6a4","metadata":{"execution":{"iopub.execute_input":"2026-07-20T13:05:00.944086Z","iopub.status.busy":"2026-07-20T13:05:00.943352Z","iopub.status.idle":"2026-07-20T13:05:01.041312Z","shell.execute_reply":"2026-07-20T13:05:01.040383Z"},"papermill":{"duration":0.109651,"end_time":"2026-07-20T13:05:01.043453+00:00","exception":false,"start_time":"2026-07-20T13:05:00.933802+00:00","status":"completed"},"tags":[]},"outputs":[{"name":"stdout","output_type":"stream","text":["Points matched to counties: 15/79 (19.0%)\n","NAME           STATEFP\n","Los Angeles    06         7\n","Orange         06         7\n","Santa Barbara  06         1\n","Name: count, dtype: int64\n","Transport-weighted PM2.5: 18.690 µg/m³\n","LA's own PM2.5 on Sep 21 2020: [25.92502655]\n"]}],"source":["# what % of trajectory points matched a US county?\n","total_points = len(joined)\n","matched_points = joined['GEOID'].notna().sum()\n","print(f\"Points matched to counties: {matched_points}/{total_points} ({100*matched_points/total_points:.1f}%)\")\n","\n","# which counties appeared?\n","print(joined.dropna(subset=['GEOID'])[['NAME', 'STATEFP']].value_counts().head(10))\n","\n","# did PM2.5 match?\n","print(f\"Transport-weighted PM2.5: {tw_pm25:.3f} µg/m³\")\n","print(f\"LA's own PM2.5 on Sep 21 2020: {pm[(pm['GEOID']=='06037') & (pm['date']=='2020-09-21')]['pm25_ushigh'].values}\")"]},{"cell_type":"code","execution_count":21,"id":"20411650","metadata":{"execution":{"iopub.execute_input":"2026-07-20T13:05:01.062824Z","iopub.status.busy":"2026-07-20T13:05:01.062549Z","iopub.status.idle":"2026-07-20T13:05:01.169757Z","shell.execute_reply":"2026-07-20T13:05:01.168709Z"},"papermill":{"duration":0.118331,"end_time":"2026-07-20T13:05:01.171266+00:00","exception":false,"start_time":"2026-07-20T13:05:01.052935+00:00","status":"completed"},"tags":[]},"outputs":[{"name":"stdout","output_type":"stream","text":["==================================================\n","FEASIBILITY CHECK — Sep 21, 2020\n","==================================================\n","\n","1. SPATIAL JOIN\n","   Total trajectory points     : 79\n","   Matched to US counties      : 15\n","   Over ocean (NaN)            : 64\n","   Match rate                  : 19.0%\n","\n","2. COUNTIES IDENTIFIED\n","GEOID          NAME  transport_weight\n","06037   Los Angeles          0.543407\n","06059        Orange          0.434754\n","06083 Santa Barbara          0.021840\n","\n","3. PM2.5 LINKAGE\n","   Points with PM2.5 matched   : 15\n","   Points missing PM2.5        : 0\n","GEOID          NAME  lag   weight  pm25_ushigh\n","06037   Los Angeles  0.0 1.000000    25.925027\n","06037   Los Angeles  1.0 0.959189    21.752326\n","06037   Los Angeles  2.0 0.920044    21.752326\n","06037   Los Angeles  3.0 0.882497    21.752326\n","06037   Los Angeles  4.0 0.846482    21.752326\n","06037   Los Angeles  5.0 0.811936    21.752326\n","06059        Orange  7.0 0.747018    14.364710\n","06059        Orange  8.0 0.716531    14.364710\n","06059        Orange  9.0 0.687289    14.364710\n","06059        Orange 10.0 0.659241    14.364710\n","06059        Orange 11.0 0.632337    14.364710\n","06059        Orange 12.0 0.606531    14.364710\n","06059        Orange 13.0 0.581778    14.364710\n","06037   Los Angeles 24.0 0.367879    21.752326\n","06083 Santa Barbara 35.0 0.232624    10.674347\n","\n","4. TRANSPORT-WEIGHTED PM2.5\n","   Incoming air mass PM2.5     : 18.690 µg/m³\n","\n","5. LA OWN PM2.5 ON SEP 21 2020\n","   LA County PM2.5             : 25.925 µg/m³\n","\n","==================================================\n","CONCLUSION: Pipeline feasibility confirmed\n","==================================================\n"]}],"source":["# LA county FIPS is 06037\n","la_pm25 = pm[\n","    (pm['GEOID'] == '06037') & \n","    (pm['date'] == '2020-09-21')\n","]['pm25_ushigh'].values\n","\n","print(\"=\" * 50)\n","print(\"FEASIBILITY CHECK — Sep 21, 2020\")\n","print(\"=\" * 50)\n","\n","print(f\"\\n1. SPATIAL JOIN\")\n","print(f\"   Total trajectory points     : {len(joined)}\")\n","print(f\"   Matched to US counties      : {joined['GEOID'].notna().sum()}\")\n","print(f\"   Over ocean (NaN)            : {joined['GEOID'].isna().sum()}\")\n","print(f\"   Match rate                  : {100*joined['GEOID'].notna().sum()/len(joined):.1f}%\")\n","\n","print(f\"\\n2. COUNTIES IDENTIFIED\")\n","print(county_weights[['GEOID','NAME','transport_weight']].to_string(index=False))\n","\n","print(f\"\\n3. PM2.5 LINKAGE\")\n","print(f\"   Points with PM2.5 matched   : {valid['GEOID'].count()}\")\n","print(f\"   Points missing PM2.5        : {merged['pm25_ushigh'].isna().sum()}\")\n","print(merged[['GEOID','NAME','lag','weight','pm25_ushigh']].to_string(index=False))\n","\n","print(f\"\\n4. TRANSPORT-WEIGHTED PM2.5\")\n","print(f\"   Incoming air mass PM2.5     : {transport_weighted_pm25:.3f} µg/m³\")\n","\n","print(f\"\\n5. LA OWN PM2.5 ON SEP 21 2020\")\n","if len(la_pm25) > 0:\n","    print(f\"   LA County PM2.5             : {la_pm25[0]:.3f} µg/m³\")\n","else:\n","    print(\"   LA County PM2.5             : Not found in dataset\")\n","\n","print(\"\\n\" + \"=\" * 50)\n","print(\"CONCLUSION: Pipeline feasibility confirmed\" if not np.isnan(transport_weighted_pm25) \n","      else \"CONCLUSION: PM2.5 linkage returned NaN — check date format or GEOID format\")\n","print(\"=\" 