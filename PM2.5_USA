   "source": [
    "import folium\n",
    "\n",
    "def plot_trajectory_folium(traj1, traj2):\n",
    "    # center map on LA\n",
    "    m = folium.Map(location=[34.052, -118.244], zoom_start=4)\n",
    "    \n",
    "    # trajectory 1 (500m) — red line\n",
    "    points1 = list(zip(traj1['lat'], traj1['lon']))\n",
    "    folium.PolyLine(\n",
    "        points1,\n",
    "        color='red',\n",
    "        weight=2.5,\n",
    "        opacity=0.8,\n",
    "        tooltip='Trajectory 1 (500m AGL)'\n",
    "    ).add_to(m)\n",
    "    \n",
    "    # trajectory 2 (300m) — blue line\n",
    "    points2 = list(zip(traj2['lat'], traj2['lon']))\n",
    "    folium.PolyLine(\n",
    "        points2,\n",
    "        color='blue',\n",
    "        weight=2.5,\n",
    "        opacity=0.8,\n",
    "        tooltip='Trajectory 2 (300m AGL)'\n",
    "    ).add_to(m)\n",
    "    \n",
    "    # mark LA arrival point\n",
    "    folium.Marker(\n",
    "        location=[34.052, -118.244],\n",
    "        popup='Los Angeles (Arrival Point)<br>Sep 21, 2020 00:00 UTC',\n",
    "        icon=folium.Icon(color='red', icon='star')\n",
    "    ).add_to(m)\n",
    "    \n",
    "    # mark origin points (72h back)\n",
    "    folium.Marker(\n",
    "        location=[traj1['lat'].iloc[-1], traj1['lon'].iloc[-1]],\n",
    "        popup=f\"Traj 1 Origin (72h back)<br>Lat: {traj1['lat'].iloc[-1]:.2f}<br>Lon: {traj1['lon'].iloc[-1]:.2f}\",\n",
    "        icon=folium.Icon(color='green', icon='flag')\n",
    "    ).add_to(m)\n",
    "    \n",
    "    folium.Marker(\n",
    "        location=[traj2['lat'].iloc[-1], traj2['lon'].iloc[-1]],\n",
    "        popup=f\"Traj 2 Origin (72h back)<br>Lat: {traj2['lat'].iloc[-1]:.2f}<br>Lon: {traj2['lon'].iloc[-1]:.2f}\",\n",
    "        icon=folium.Icon(color='blue', icon='flag')\n",
    "    ).add_to(m)\n",
    "    \n",
    "    # add hourly points with tooltips\n",
    "    for _, row in traj1.iterrows():\n",
    "        folium.CircleMarker(\n",
    "            location=[row['lat'], row['lon']],\n",
    "            radius=3,\n",
    "            color='red',\n",
    "            fill=True,\n",
    "            tooltip=f\"Age: {row['age_hours']}h | Alt: {row['alt']}m | Temp: {row['air_temp']}K\"\n",
    "        ).add_to(m)\n",
    "    \n",
    "    return m\n",
    "\n",
    "m = plot_trajectory_folium(traj1, traj2)\n",
    "m.save('trajectory_map.html')\n",
    "m  # displays inline in Kaggle notebook"
   ]
  }
 ],
