    "from shapely.geometry import Point\n",
    "# from shapely.geometry import Point: Imports a specific \n",
    "# blueprint to create explicit coordinates. Shapefiles and geographic maps cannot understand a plain text latitude and longitude column until you explicitly bundle them into a Python Point object."
   ]
