n_24b1ff0a0d2f56cb7d0807b18c00c937);\n","            \n","    \n","                marker_f99a2f004ec34b6529c4b032fd2f485c.setIcon(icon_1da54430c5e580d0d7a6f37d4ebcdfd2);\n","            \n","&lt;/script&gt;\n","&lt;/html&gt;\" style=\"position:absolute;width:100%;height:100%;left:0;top:0;border:none !important;\" allowfullscreen webkitallowfullscreen mozallowfullscreen></iframe></div></div>"],"text/plain":["<folium.folium.Map at 0x7f8ff40c34a0>"]},"execution_count":11,"metadata":{},"output_type":"execute_result"}],"source":["import folium\n","\n","def plot_trajectory_folium(traj1, traj2):\n","    # center map on LA\n","    m = folium.Map(location=[34.052, -118.244], zoom_start=4)\n","    \n","    # trajectory 1 (500m) — red line\n","    points1 = list(zip(traj1['lat'], traj1['lon']))\n","    folium.PolyLine(\n","        points1,\n","        color='red',\n","        weight=2.5,\n","        opacity=0.8,\n","        tooltip='Trajectory 1 (500m AGL)'\n","    ).add_to(m)\n","    \n","    # trajectory 2 (300m) — blue line\n","    points2 = list(zip(traj2['lat'], traj2['lon']))\n","    folium.PolyLine(\n","        points2,\n","        color='blue',\n","        weight=2.5,\n","        opacity=0.8,\n","        tooltip='Trajectory 2 (300m AGL)'\n","    ).add_to(m)\n","    \n","    # mark LA arrival point\n","    folium.Marker(\n","        location=[34.052, -118.244],\n","        popup='Los Angeles (Arrival Point)<br>Sep 21, 2020 00:00 UTC',\n","        icon=folium.Icon(color='red', icon='star')\n","    ).add_to(m)\n","    \n","    # mark origin points (72h back)\n","    folium.Marker(\n","        location=[traj1['lat'].iloc[-1], traj1['lon'].iloc[-1]],\n","        popup=f\"Traj 1 Origin (72h back)<br>Lat: {traj1['lat'].iloc[-1]:.2f}<br>Lon: {traj1['lon'].iloc[-1]:.2f}\",\n","        icon=folium.Icon(color='green', icon='flag')\n","    ).add_to(m)\n","    \n","    folium.Marker(\n","        location=[traj2['lat'].iloc[-1], traj2['lon'].iloc[-1]],\n","        popup=f\"Traj 2 Origin (72h back)<br>Lat: {traj2['lat'].iloc[-1]:.2f}<br>Lon: {traj2['lon'].iloc[-1]:.2f}\",\n","        icon=folium.Icon(color='blue', icon='flag')\n","    ).add_to(m)\n","    \n","    # add hourly points with tooltips\n","    for _, row in traj1.iterrows():\n","        folium.CircleMarker(\n","            location=[row['lat'], row['lon']],\n","            radius=3,\n","            color='red',\n","            fill=True,\n","            tooltip=f\"Age: {row['age_hours']}h | Alt: {row['alt']}m | Temp: {row['air_temp']}K\"\n","        ).add_to(m)\n","    \n","    return m\n","\n","m = plot_trajectory_folium(traj1, traj2)\n","m.save('trajectory_map.html')\n","m  # displays inline in Kaggle notebook"]},{"cell_type":"markdown","id":"cb68a281","metadata":{"papermill":{"duration":0.008853,"end_time":"2026-07-20T13:04:55.786978+00:00","exception":false,"start_time":"2026-07-20T13:04:55.778125+00:00","status":"completed"},"tags":[]},"source":["# STEP 3 — Spatial Join (single .tdump)\n","This confirms the pipeline works before scaling. Points over the Pacific Ocean will have NaN for GEOID "]},{"cell_type":"code","execution_count":12,"id":"5af696b7","metadata":{"execution":{"iopub.execute_input":"2026-07-20T13:04:55.806261Z","iopub.status.busy":"2026-07-20T13:04:55.805395Z","iopub.status.idle":"2026-07-20T13:04:57.520884Z","shell.execute_reply":"2026-07-20T13:04:57.520012Z"},"papermill":{"duration":1.726724,"end_time":"2026-07-20T13:04:57.522574+00:00","exception":false,"start_time":"2026-07-20T13:04:55.79585+00:00","status":"completed"},"tags":[]},"outputs":[{"name":"stdout","output_type":"stream","text":["              datetime  age_hours     lat      lon    alt  GEOID         NAME  \\\n","0  2020-09-21 00:00:00        0.0  34.052 -118.244  500.0  06037  Los Angeles   \n","1  2020-09-20 23:00:00       -1.0  33.992 -118.240  507.6  06037  Los Angeles   \n","2  2020-09-20 22:00:00       -2.0  33.930 -118.235  515.8  06037  Los Angeles   \n","3  2020-09-20 21:00:00       -3.0  