   "source": [
    "traj1 = df[df['traj_num'] == 1].reset_index(drop=True)  # 500m start\n",
    "traj2 = df[df['traj_num'] == 2].reset_index(drop=True)  # 300m start\n",
    "\n",
    "print(f\"Trajectory 1 points: {len(traj1)}\")  # should be ~78 (0 to -78 hours)\n",
    "print(f\"Trajectory 2 points: {len(traj2)}\")"
   ]
  },
  {
