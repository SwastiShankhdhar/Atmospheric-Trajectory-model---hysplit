001  2020-01-06     7.153534  USHighPM2.5_D1K\n","6         1001  2020-01-07     5.372725  USHighPM2.5_D1K\n","7         1001  2020-01-08     8.742722  USHighPM2.5_D1K\n","8         1001  2020-01-09     9.495644  USHighPM2.5_D1K\n","9         1001  2020-01-10     7.167633  USHighPM2.5_D1K"]},"execution_count":3,"metadata":{},"output_type":"execute_result"}],"source":["pm.head(10)"]},{"cell_type":"code","execution_count":4,"id":"607a431a","metadata":{"execution":{"iopub.execute_input":"2026-07-20T13:04:53.178625Z","iopub.status.busy":"2026-07-20T13:04:53.177961Z","iopub.status.idle":"2026-07-20T13:04:53.296135Z","shell.execute_reply":"2026-07-20T13:04:53.295073Z"},"papermill":{"duration":0.12651,"end_time":"2026-07-20T13:04:53.297608+00:00","exception":false,"start_time":"2026-07-20T13:04:53.171098+00:00","status":"completed"},"tags":[]},"outputs":[{"name":"stdout","output_type":"stream","text":["(1183278, 4)\n","<class 'pandas.core.frame.DataFrame'>\n","RangeIndex: 1183278 entries, 0 to 1183277\n","Data columns (total 4 columns):\n"," #   Column       Non-Null Count    Dtype  \n","---  ------       --------------    -----  \n"," 0   county_fips  1183278 non-null  int64  \n"," 1   date         1183278 non-null  object \n"," 2   pm25_ushigh  1137528 non-null  float64\n"," 3   source       1183278 non-null  object \n","dtypes: float64(1), int64(1), object(2)\n","memory usage: 36.1+ MB\n","None\n"]}],"source":["print(pm.shape)\n","print(pm.info())"]},{"cell_type":"code","execution_count":5,"id":"8249c655","metadata":{"execution":{"iopub.execute_input":"2026-07-20T13:04:53.311805Z","iopub.status.busy":"2026-07-20T13:04:53.311217Z","iopub.status.idle":"2026-07-20T13:04:53.52743Z","shell.execute_reply":"2026-07-20T13:04:53.526033Z"},"papermill":{"duration":0.225267,"end_time":"2026-07-20T13:04:53.529345+00:00","exception":false,"start_time":"2026-07-20T13:04:53.304078+00:00","status":"completed"},"tags":[]},"outputs":[{"name":"stdout","output_type":"stream","text":["2020-01-01\n","2020-12-31\n","366\n"]}],"source":["print(pm['date'].min())\n","print(pm['date'].max())\n","print(pm['date'].nunique())"]},{"cell_type":"markdown","id":"9597f805","metadata":{"papermill":{"duration":0.007318,"end_time":"2026-07-20T13:04:53.544421+00:00","exception":false,"start_time":"2026-07-20T13:04:53.537103+00:00","status":"completed"},"tags":[]},"source":["# ABOUT TRAJECTORY FILE FROM THE HYSPLIT MODEL"]},{"cell_type":"markdown","id":"dacbb4f4","metadata":{"papermill":{"duration":0.00725,"end_time":"2026-07-20T13:04:53.559511+00:00","exception":false,"start_time":"2026-07-20T13:04:53.552261+00:00","status":"completed"},"tags":[]},"source":["## Reading Your Actual File\n","Looking at your data, Record #6 (the data rows) looks like this:\n","\n","     1     1    20     9    21     0     0     0     0.0   34.052 -118.244    500.0    943.3    301.4    296.4      0.0\n","  [traj] [grid] [yr] [mo] [dy] [hr] [min] [fhr] [age]   [lat]    [lon]     [alt]  [pres]  [theta] [airtemp] [rain]\n","\n","  \n","Your file has 2 trajectories (trajectory 1 = 500m start, trajectory 2 = 300m start) and 4 diagnostic variables: PRESSURE, THETA, AIR_TEMP, RAINFALL."]},{"cell_type":"markdown","id":"19c428bd","metadata":{"papermill":{"duration":0.00614,"end_time":"2026-07-20T13:04:53.572466+00:00","exception":false,"start_time":"2026-07-20T13:04:53.566326+00:00","status":"completed"},"tags":[]},"source":["# Step 1 Parsing the trajectory"]},{"cell_type":"code","execution_count":6,"id":"b6c678c4","metadata":{"execution":{"iopub.execute_input":"2026-07-20T13:04:53.586286Z","iopub.status.busy":"2026-07-20T13:04:53.586Z","iopub.status.idle":"2026-07-20T13:04:53.595304Z","shell.execute_reply":"2026-07-20T13:04:53.594711Z"},"papermill":{"duration":0.017789,"end_time":"2026-07-20T13:04:53.596655+00:00","exception":false,"start_time":"2026-07-20T13:04:53.578866+00:00","status":"completed"},"tags":[]},"outputs":[],"source":["import pandas as pd\n","import geopandas as gpd\n","from shapely.geometry import Point\n","\n","def parse_tdump(filepath):\n","    rows = []\n","    \n","    with open(filepath, 'r') as f:\n","        lines = f.readlines()\n","    \n","    for line in lines:\n","        parts = line.strip().split()\n","        \n","        # data lines have 15 columns (6 base + fhr + age + lat + lon + alt + 4 diag vars)\n","        if len(parts) < 15:\n","            continue\n","        \n","        try:\n","            traj_num  = int(parts[0])\n","            grid_num  = int(parts[1])\n","            year      = int(parts[2])\n","            month     = int(parts[3])\n","            day       = int(parts[4])\n","            hour      = int(parts[5])\n","            minute    = int(parts[6])\n","            fhour     = int(parts[7])\n","            age       = float(parts[8])   # negative = backward hours\n","            lat       = float(parts[9])\n","            lon       = float(parts[10])\n","            alt       = float(parts[11])\n","            pressure  = float(parts[12])\n","            theta     = float(parts[13])\n","            air_temp  = float(parts[14])\n","            rainfall  = float(parts[15]) if len(parts) > 15 else None\n","            \n","            rows.append({\n","                'traj_num': traj_num,\n","                'year': year, 'month': month, 'day': day,\n","                'hour': hour, 'minute': minute,\n","                'age_hours': age,\n","                'lat': lat, 'lon': lon, 'alt': alt,\n","                'pressure': pressure,\n","                'theta': theta,\n","                'air_temp': air_temp,\n","                'rainfall': rainfall\n","            })\n","        except (ValueError, IndexError):\n","            continue  # skip header lines cleanly\n","    \n","    df = pd.DataFrame(rows)\n","    \n","    # create proper datetime column\n","    df['datetime'] = pd.to_datetime({\n","        'year':  2000 + df['year'],   # HYSPLIT uses 2-digit year\n","        'month': df['month'],\n","        'day':   df['day'],\n","        'hour':  df['hour']\n","    })\n","    \n","    return df\n","\n"]},{"cell_type":"code","execution_count":7,"id":"ef97c213","metadata":{"execution":{"iopub.execute_input":"2026-07-20T13:04:53.610931Z","iopub.status.busy":"2026-07-20T13:04:53.61019Z","iopub.status.idle":"2026-07-20T13:04:53.636135Z","shell.execute_reply":"2026-07-20T13:04:53.63502Z"},"papermill":{"duration":0.034693,"end_time":"2026-07-20T13:04:53.637603+00:00","exception":false,"start_time":"2026-07-20T13:04:53.60291+00:00","status":"completed"},"tags":[]},"outputs":[{"name":"stdout","output_type":"stream","text":["   traj_num  year  month  day  hour  minute  age_hours     lat      lon  \\\n","0         1    20      9   21     0       0        0.0  34.052 -118.244   \n","1         2    20      9   21     0       0        0.0  34.052 -118.244   \n","2         1    20      9   20    23       0       -1.0  33.992 -118.240   \n","3         2    20      9   20    23       0       -1.0  33.979 -118.291   \n","4         1    20      9   20    22       0       -2.0  33.930 -118.235   \n","5         2    20      9   20    22       0       -2.0  33.897 -118.347   \n","6         1    20      9   20    21       0       -3.0  33.868 -118.238   \n","7         2    20      9   20    21       0       -3.0  33.806 -118.417   \n","8         1    20      9   20    20       0       -4.0  33.814 -118.233   \n","9         2    20      9   20    20       0       -4.0  33.723 -118.495   \n","\n","     alt  pressure  theta  air_temp  rainfall            datetime  \n","0  500.0     943.3  301.4     296.4       0.0 2020-09-21 00:00:00  \n","1  300.0     965.1  299.1     296.1       0.0 2020-09-21 00:00:00  \n","2  507.6     946.1  301.0     296.3       0.0 2020-09-20 23:00:00  \n","3  260.8     973.7  298.4     296.1       0.0 2020-09-20 23:00:00  \n","4  515.8     945.8  301.0     296.3       0.0 2020-09-20 22:00:00  \n","5  207.9     980.8  297.8     296.1       0.0 2020-09-20 22:00:00  \n","6  527.8     945.1  301.0     296.2       0.0 2020-09-20 21:00:00  \n","7  153.4     987.8  298.1     297.0       0.0 2020-09-20 21:00:00  \n","8  548.9     943.6  300.9     295.9       0.0 2020-09-20 20:00:00  \n","9  114.0     993.9  296.2     295.7       0.0 2020-09-20 20:00:00  \n","[1 2]\n","2020-09-17 18:00:00 2020-09-21 00:00:00\n"]}],"source":["df = parse_tdump('/kaggle/input/datasets/swastishankhdhar/tdump-file-hysplit/tdump.112524.txt')\n","print(df.head(10))\n","print(df['traj_num'].unique())   # should show [1, 2]\n","print(df['datetime'].min(), df['datetime'].max())"]},{"cell_type":"markdown","id":"46510efd","metadata":{"papermill":{"duration":0.006174,"end_time":"2026-07-20T13:04:53.650103+00:00","exception":false,"start_time":"2026-07-20T13:04:53.643929+00:00","status":"completed"},"tags":[]},"source":["file has 20 for year, 9 for month — meaning September 2020. HYSPLIT stores 2-digit years, so you need 2000 + 20 = 2020. The parser handles this already."]},{"cell_type":"markdown","id":"83e9e16b","metadata":{"papermill":{"duration":0.006104,"end_time":"2026-07-20T13:04:53.662585+00:00","exception":false,"start_time":"2026-07-20T13:04:53.656481+00:00","status":"completed"},"tags":[]},"source":["## After Parsing — Split by Trajectory\n","Your file has 2 trajectories interleaved. Separate them:"]},{"cell_type":"code","execution_count":8,"id":"ed02ba7b","metadata":{"execution":{"iopub.execute_input":"2026-07-20T13:04:53.676354Z","iopub.status.busy":"2026-07-20T13:04:53.676101Z","iopub.status.idle":"2026-07-20T13:04:53.682Z","shell.execute_reply":"2026-07-20T13:04:53.681161Z"},"papermill":{"duration":0.014438,"end_time":"2026-07-20T13:04:53.683405+00:00","exception":false,"start_time":"2026-07-20T13:04:53.668967+00:00","status":"completed"},"tags":[]},"outputs":[{"name":"stdout","output_type":"stream","text":["Trajectory 1 points: 79\n","Trajectory 2 points: 79\n"]}],"source":["traj1 = df[df['traj_num'] == 1].reset_index(drop=True)  # 500m start\n","traj2 = df[df['traj_num'] == 2].reset_index(drop=True)  # 300m start\n","\n","print(f\"Trajectory 1 points: {len(traj1)}\")  # should be ~78 (0 to -78 hours)\n","print(f\"Trajectory 2 points: {len(traj2)}\")"]},{"cell_type":"markdown","id":"ec2644e0","metadata":{"papermill":{"duration":0.006689,"end_time":"2026-07-20T13:04:53.6968+00:00","exception":false,"start_time":"2026-07-20T13:04:53.690111+00:00","status":"completed"},"tags":[]},"source":["## Then Convert to GeoDataFrame"]},{"cell_type":"code","execution_count":9,"id":"3a6e2b80","metadata":{"execution":{"iopub.execute_input":"2026-07-20T13:04:53.711069Z","iopub.status.busy":"2026-07-20T13:04:53.710866Z","iopub.status.idle":"2026-07-20T13:04:53.751382Z","shell.execute_reply":"2026-07-20T13:04:53.750422Z"},"papermill":{"duration":0.049582,"end_time":"2026-07-20T13:04:53.752919+00:00","exception":false,"start_time":"2026-07-20T13:04:53.703337+00:00","status":"completed"},"tags":[]},"outputs":[{"name":"stdout","output_type":"stream","text":["             datetime  age_hours     lat      lon    alt  \\\n","0 2020-09-21 00:00:00        0.0  34.052 -118.244  500.0   \n","1 2020-09-20 23:00:00       -1.0  33.992 -118.240  507.6   \n","2 2020-09-20 22:00:00       -2.0  33.930 -118.235  515.8   \n","3 2020-09-20 21:00:00       -3.0  33.868 -118.238  527.8   \n","4 2020-09-20 20:00:00       -4.0  33.814 -118.233  548.9   \n","\n","                  geometry  \n","0  POINT (-118.244 34.052)  \n","1   POINT (-118.24 33.992)  \n","2   POINT (-118.235 33.93)  \n","3  POINT (-118.238 33.868)  \n","4  POINT (-118.233 33.814)  \n"]}],"source":["def to_geodataframe(df):\n","    geometry = [Point(lon, lat) for lon, lat in zip(df['lon'], df['lat'])]\n","    return gpd.GeoDataFrame(df, geometry=geometry, crs='EPSG:4326')\n","\n","gdf1 = to_geodataframe(traj1)\n","gdf2 = to_geodataframe(traj2)\n","\n","print(gdf1[['datetime', 'age_hours', 'lat', 'lon', 'alt', 'geometry']].head())"]},{"cell_type":"markdown","id":"54b81f7f","metadata":{"papermill":{"duration":0.006226,"end_time":"2026-07-20T13:04:53.765503+00:00","exception":false,"start_time":"2026-07-20T13:04:53.759277+00:00","status":"completed"},"tags":[]},"source":["# step 2 Visualising the trajectory"]},{"cell_type":"markdown","id":"5962f88e","metadata":{"papermill":{"duration":0.0064,"end_time":"2026-07-20T13:04:53.778259+00:00","exception":false,"start_time":"2026-07-20T13:04:53.771859+00:00","status":"completed"},"tags":[]},"source":["# GeoPandas Map (Basic)"]},{"cell_type":"code","execution_count":10,"id":"a29117a1","metadata":{"execution":{"iopub.execute_input":"2026-07-20T13:04:53.792204Z","iopub.status.busy":"2026-07-20T13:04:53.791999Z","iopub.status.idle":"2026-07-20T13:04:55.319125Z","shell.execute_reply":"2026-07-20T13:04:55.318143Z"},"papermill":{"duration":1.536444,"end_time":"2026-07-20T13:04:55.321076+00:00","exception":false,"start_time":"2026-07-20T13:04:53.784632+00:00","status":"completed"},"tags":[]},"outputs":[{"data":{"image/png":"\n","text/plain":["<Figure size 1200x600 with 1 Axes>"]},"metadata":{},"output_type":"display_data"}],"source":["import matplotlib.pyplot as plt\n","import geopandas as gpd\n","from shapely.geometry import LineString\n","import requests, zipfile, io\n","\n","# download naturalearth countries shapefile directly\n","url = \"https://naciscdn.org/naturalearth/110m/cultural/ne_110m_admin_0_countries.zip\"\n","r = requests.get(url)\n","z = zipfile.ZipFile(io.BytesIO(r.content))\n","z.extractall('/kaggle/working/world/')\n","\n","world = gpd.read_file('/kaggle/working/world/ne_110m_admin_0_countries.shp')\n","\n","# create line from trajectory 1 points\n","line = LineString(zip(traj1['lon'], traj1['lat']))\n","gdf_line = gpd.GeoDataFrame(geometry=[line], crs='EPSG:4326')\n","\n","fig, ax = plt.subplots(figsize=(12, 6))\n","world.plot(ax=ax, color='lightgray', edgecolor='white')\n","gdf_line.plot(ax=ax, color='red', linewidth=2, label='Traj 1 (500m)')\n","\n","# plot start and end points\n","ax.scatter(-118.244, 34.052, color='blue', s=100, zorder=5, label='LA (arrival)')\n","ax.scatter(traj1['lon'].iloc[-1], traj1['lat'].iloc[-1],\n","           color='green', s=100, zorder=5, label='Origin (72h back)')\n","\n","ax.set_xlim(-145, -110)\n","ax.set_ylim(25, 55)\n","ax.set_title('72-hour Backward Trajectory — Los Angeles (Sep 21, 2020)')\n","ax.legend()\n","plt.tight_layout()\n","plt.show()"]},{"cell_type":"markdown","id":"ba1e4cc5","metadata":{"papermill":{"duration":0.010313,"end_time":"2026-07-20T13:04:55.345365+00:00","exception":false,"start_time":"2026-07-20T13:04:55.335052+00:00","status":"completed"},"tags":[]},"source":["# Folium Map (Interactive — Recommended)"]},{"cell_type":"code","execution_count":11,"id":"a237aacd","metadata":{"execution":{"iopub.execute_input":"2026-07-20T13:04:55.361822Z","iopub.status.busy":"2026-07-20T13:04:55.361346Z","iopub.status.idle":"2026-07-20T13:04:55.767107Z","shell.execute_reply":"2026-07-20T13:04:55.766226Z"},"papermill":{"duration":0.415745,"end_time":"2026-07-20T13:04:55.768645+00:00","exception":false,"start_time":"2026-07-20T13:04:55.3529+00:00","status":"completed"},"tags":[]},"outputs":[{"data":{"text/html":["<div style=\"width:100%;\"><div style=\"position:relative;width:100%;height:0;padding-bottom:60%;\"><span style=\"color:#565656\">Make this Notebook Trusted to load map: File -> Trust Notebook</span><iframe srcdoc=\"&lt;!DOCTYPE html&gt;\n","&lt;html&gt;\n","&lt;head&gt;\n","    \n","    &lt;meta http-equiv=&quot;content-type&quot; content=&quot;text/html; charset=UTF-8&quot; /&gt;\n","    &lt;script src=&quot;https://cdn.jsdelivr.net/npm/leaflet@1.9.3/dist/leaflet.js&quot;&gt;&lt;/script&gt;\n","    &lt;script src=&quot;https://code.jquery.com/jquery-3.7.1.min.js&quot;&gt;&lt;/script&gt;\n","    &lt;script src=&quot;https://cdn.jsdelivr.net/npm/bootstrap@5.2.2/dist/js/bootstrap.bundle.min.js&quot;&gt;&lt;/script&gt;\n","    &lt;script src=&quot;https://cdnjs.cloudflare.com/ajax/libs/Leaflet.awesome-marker