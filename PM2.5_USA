    "# GeoPandas Map (Basic)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "id": "9e7a6b18",
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-07-19T12:18:59.412582Z",
     "iopub.status.busy": "2026-07-19T12:18:59.412389Z",
     "iopub.status.idle": "2026-07-19T12:19:00.283130Z",
     "shell.execute_reply": "2026-07-19T12:19:00.282471Z"
    },
    "papermill": {
     "duration": 0.876536,
     "end_time": "2026-07-19T12:19:00.285315+00:00",
     "exception": false,
     "start_time": "2026-07-19T12:18:59.408779+00:00",
     "status": "completed"
    },
    "tags": []
   },
   "outputs": [
    {
     "data": {
      "image/png": "\n",
      "text/plain": [
       "<Figure size 1200x600 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "import matplotlib.pyplot as plt\n",
    "import geopandas as gpd\n",
    "from shapely.geometry import LineString\n",
    "import requests, zipfile, io\n",
    "\n",
    "# download naturalearth countries shapefile directly\n",
    "url = \"https://naciscdn.org/naturalearth/110m/cultural/ne_110m_admin_0_countries.zip\"\n",
    "r = requests.get(url)\n",
    "z = zipfile.ZipFile(io.BytesIO(r.content))\n",
    "z.extractall('/kaggle/working/world/')\n",
    "\n",
    "world = gpd.read_file('/kaggle/working/world/ne_110m_admin_0_countries.shp')\n",
    "\n",
    "# create line from trajectory 1 points\n",
    "line = LineString(zip(traj1['lon'], traj1['lat']))\n",
    "gdf_line = gpd.GeoDataFrame(geometry=[line], crs='EPSG:4326')\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(12, 6))\n",
    "world.plot(ax=ax, color='lightgray', edgecolor='white')\n",
    "gdf_line.plot(ax=ax, color='red', linewidth=2, label='Traj 1 (500m)')\n",
    "\n",
    "# plot start and end points\n",
    "ax.scatter(-118.244, 34.052, color='blue', s=100, zorder=5, label='LA (arrival)')\n",
    "ax.scatter(traj1['lon'].iloc[-1], traj1['lat'].iloc[-1],\n",
    "           color='green', s=100, zorder=5, label='Origin (72h back)')\n",
    "\n",
    "ax.set_xlim(-145, -110)\n",
    "ax.set_ylim(25, 55)\n",
    "ax.set_title('72-hour Backward Trajectory — Los Angeles (Sep 21, 2020)')\n",
    "ax.legend()\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
